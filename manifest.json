{
  "manifest_version": 3,
  "name": "Genius Veritas",
  "version": "1.0",
  "description": "Genius Türkiye için Chorme eklentisi.",
  "icons": {
    "16": "src/ico/icon.png",
    "32": "src/ico/icon.png",
    "48": "src/ico/icon.png",
    "128": "src/ico/icon.png"
  },
  "permissions": [
    "clipboardRead",
    "clipboardWrite",
    "activeTab",
    "scripting",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.genius.com/*"
      ],
      "js": [
        "src/ozellikler/preload.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.genius.com/*"
      ],
      "css": [
        "src/css/content.css"
      ],
      "js": [
        "src/ozellikler/songpage.js",
        "src/ozellikler/albumpage.js"
      ]
    },
    {
      "matches": [
        "*://open.spotify.com/*"
      ],
      "js": [
        "src/ozellikler/spotify_main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://open.spotify.com/*"
      ],
      "js": [
        "src/ozellikler/spotify.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Genius Veritas"
  }
}